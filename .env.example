# ============================================
# REGALS MONITORING SYSTEM - ENVIRONMENT TEMPLATE
# ============================================
# Copy this file to .env and fill in your actual values
# OR set these in Render dashboard Environment Variables
# NEVER commit .env with real values to GitHub
# ============================================

# ============================================
# DATABASE (MongoDB Atlas FREE M0 Cluster)
# ============================================
# Get your URI from MongoDB Atlas Dashboard > Database > Connect > Drivers > Node.js
MONGODB_URI={{MONGODB_URI}}

# ============================================
# AUTHENTICATION (JWT)
# ============================================
# Generate a strong random string (64+ characters recommended)
# You can use: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET={{JWT_SECRET}}

# ============================================
# EMAIL SERVICE (Forgot Password)
# ============================================
# Using Gmail with App Password
# 1. Enable 2FA on your Gmail account
# 2. Generate App Password at: Google Account > Security > 2-Step Verification > App passwords
# 3. Select "Mail" and "Other (Custom name)" -> "Regals Monitoring"
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER={{EMAIL_USER}}
EMAIL_APP_PASSWORD={{EMAIL_APP_PASSWORD}}

# Alternative: Keep backwards compatibility with existing GMAIL_ vars
GMAIL_EMAIL={{EMAIL_USER}}
GMAIL_APP_PASSWORD={{EMAIL_APP_PASSWORD}}

# ============================================
# SERVER CONFIGURATION
# ============================================
# Render will set PORT automatically, fallback to 5000 for local dev
PORT=5000

# Set to 'production' on Render, 'development' for local
NODE_ENV=production

# ============================================
# CORS - Allowed Origins (comma-separated)
# ============================================
# For production, list your deployed web domains:
# ALLOWED_ORIGINS=https://your-tenant-site.onrender.com,https://your-admin-site.onrender.com
# 
# For development (allows all - NOT for production):
ALLOWED_ORIGINS=*

# ============================================
# FRONTEND URLS (for email links and redirects)
# ============================================
# These are used for password reset email links
TENANT_WEB_URL={{API_BASE_URL}}
ADMIN_WEB_URL={{API_BASE_URL}}/admin

# ============================================
# OPTIONAL: API Rate Limiting
# ============================================
# RATE_LIMIT_WINDOW_MS=900000
# RATE_LIMIT_MAX_REQUESTS=100
