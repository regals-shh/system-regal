<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Development domains -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">localhost</domain>
        <domain includeSubdomains="true">10.0.2.2</domain>
        <domain includeSubdomains="true">127.0.0.1</domain>
        <domain includeSubdomains="true">192.168.100.143</domain>
    </domain-config>
    
    <!-- Production domains - REPLACE WITH YOUR ACTUAL SERVER DOMAIN -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">your-production-domain.com</domain>
        <domain includeSubdomains="true">api.your-production-domain.com</domain>
    </domain-config>
    
    <!-- Allow HTTP for development (remove in production) -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system"/>
        </trust-anchors>
    </base-config>
</network-security-config>