<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="15dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvVisitorName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Visitor Name"
                android:textColor="@color/primary"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvVisitorDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Date: 01/01/2024"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/tvVisitorTimes"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="In: 08:00 AM | Out: ---"
                android:textSize="12sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="end"
            android:orientation="vertical">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnEditVisitor"
                style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginBottom="4dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:text="Edit"
                android:textColor="@color/btn_amber_text"
                android:textSize="11sp"
                android:textStyle="bold"
                app:backgroundTint="@color/btn_amber_bg"
                app:cornerRadius="8dp"
                app:icon="@android:drawable/ic_menu_edit"
                app:iconSize="14dp"
                app:iconTint="@color/btn_amber_text" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCheckout"
                style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:text="Check-out"
                android:textColor="@color/btn_red_text"
                android:textSize="11sp"
                android:textStyle="bold"
                app:backgroundTint="@color/btn_red_bg"
                app:cornerRadius="8dp"
                app:icon="@android:drawable/ic_lock_power_off"
                app:iconSize="14dp"
                app:iconTint="@color/btn_red_text" />
        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>