<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@color/bg_body">

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="@color/white"
        app:cardCornerRadius="20dp"
        app:cardElevation="2dp"
        app:strokeColor="#EEEEEE"
        app:strokeWidth="1dp"
        android:layout_marginBottom="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Add New Visitor"
                android:fontFamily="sans-serif-medium"
                android:textColor="@color/primary"
                android:textSize="18sp"
                android:layout_marginBottom="16dp" />

            <EditText
                android:id="@+id/etVisitorFirstName"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginBottom="12dp"
                android:background="@drawable/edittext_border"
                android:hint="First Name"
                android:paddingHorizontal="16dp"
                android:textSize="14sp" />

            <EditText
                android:id="@+id/etVisitorLastName"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginBottom="16dp"
                android:background="@drawable/edittext_border"
                android:hint="Last Name"
                android:paddingHorizontal="16dp"
                android:textSize="14sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnRegisterVisitor"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Register Entry"
                app:cornerRadius="16dp"
                android:backgroundTint="@color/primary"
                android:textAllCaps="false"
                android:textSize="16sp"
                android:fontFamily="sans-serif-medium" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <TextView
        android:id="@+id/tvVisitorHeader"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Active &amp; Recent Visitors (0)"
        android:fontFamily="sans-serif-medium"
        android:textColor="@color/primary"
        android:textSize="18sp"
        android:layout_marginBottom="12dp" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvVisitors"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

</LinearLayout>