<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="@color/bg_body">

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="18dp"
        app:cardElevation="4dp"
        android:layout_marginBottom="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Add New Visitor"
                android:fontFamily="serif"
                android:textColor="@color/primary"
                android:textSize="18sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/etVisitorFirstName"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="15dp"
                android:background="@drawable/edit_text_bg"
                android:hint="First Name"
                android:paddingLeft="15dp" />

            <EditText
                android:id="@+id/etVisitorLastName"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/edit_text_bg"
                android:hint="Last Name"
                android:paddingLeft="15dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnRegisterVisitor"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:layout_marginTop="15dp"
                android:text="Register Entry"
                app:cornerRadius="10dp"
                android:backgroundTint="@color/primary" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <TextView
        android:id="@+id/tvVisitorHeader"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Active &amp; Recent Visitors (0)"
        android:fontFamily="serif"
        android:textColor="@color/primary"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginBottom="10dp" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvVisitors"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

</LinearLayout>